{
  "name": "dlsite-price-tracker",
  "version": "1.0.0",
  "description": "DLsite Price Tracker",
  "main": "electron-main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "node main.js --mode=ui",
    "status": "node main.js --mode=status",
    "discover": "node main.js --mode=discover",
    "fetch": "node main.js --mode=fetch",
    "export-shards": "node main.js --mode=export-shards",
    "export-shards:push": "node main.js --mode=export-shards --push=1",
    "dist": "electron-builder --win --x64",
    "postinstall": "node scripts/postinstall-rebuild.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.0.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.dlsite.tracker",
    "productName": "DLsite Price Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "main.js",
      "config.js",
      "crawler/**",
      "server/**",
      "scripts/**",
      "node_modules/**",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**"
    ],
    "extraResources": [
      {
        "from": "server/public",
        "to": "public"
      }
    ],
    "asarUnpack": [
      "**/better-sqlite3/**",
      "**/*.node"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "DLsiteTracker-portable.exe"
    },
    "forceCodeSigning": false
  }
}
